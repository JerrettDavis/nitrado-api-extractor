{
  "name": "nitrado-api-extractor",
  "version": "0.0.1",
  "description": "Extractor for Nitrado API documentation data with OpenAPI 3.1.1 converter",
  "main": "converter.js",
  "scripts": {
    "start": "node converter.js",
    "extract": "node converter.js",
    "convert": "node convert-openapi.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint *.js __tests__/**/*.js",
    "lint:fix": "eslint *.js __tests__/**/*.js --fix",
    "help": "node converter.js --help"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nock": "^14.0.11",
    "eslint": "^10.1.0",
    "@eslint/js": "^10.0.1",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-node": "^11.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/__tests__/setup.js"],
    "collectCoverageFrom": [
      "*.js",
      "!convert-openapi.js",
      "!eslint.config.js",
      "!__tests__/**"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageDirectory": "coverage",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  },
  "keywords": [
    "nitrado",
    "api",
    "extractor",
    "documentation",
    "openapi",
    "swagger"
  ],
  "author": "",
  "license": "MIT"
}
